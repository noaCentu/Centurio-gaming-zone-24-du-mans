<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Plan - Gaming Zone</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css?v=52">
    <link rel="icon" type="image/png" href="/centurio-logo.png?v=3">
    <meta name="theme-color" content="#291834">

    <style>
        :root {
            --bg-body: #291834;
            --text-main: #ffffff;
            --text-muted: #dddddd;
            --glass-bg: rgba(41, 24, 52, 0.75);
            --glass-border: rgba(255, 255, 255, 0.15);
            --modal-bg: #1e1e1e;
            --menu-bg: #1a1a1a;
            --border-line: #444444;
            --input-bg: #2a2a2a;
            --card-bg: rgba(255,255,255,0.1);
        }
        body.light-mode {
            --bg-body: #f4f4f9;
            --text-main: #291834;
            --text-muted: #555555;
            --glass-bg: rgba(255, 255, 255, 0.95);
            --glass-border: rgba(41, 24, 52, 0.15);
            --modal-bg: #ffffff;
            --menu-bg: #ffffff;
            --border-line: #dddddd;
            --input-bg: #f9f9f9;
            --card-bg: rgba(0,0,0,0.05);
        }

        html, body { margin: 0; padding: 0; min-height: 100vh; width: 100%; background-color: var(--bg-body); font-family: 'Poppins', sans-serif; color: var(--text-main); transition: background-color 0.3s ease, color 0.3s ease; }
        
        .fullscreen-bg { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-image: url('/centurio-gaming-zone-bg.jpg'); background-size: cover; background-position: center; z-index: -10; }
        body.light-mode .fullscreen-bg { display: none; }
        
        h1, h2, h3 { color: var(--text-main) !important; text-shadow: none !important; }
        p { color: var(--text-muted) !important; line-height: 1.6; }

        /* NAVBAR TOUJOURS SOMBRE */
        .header-v2 { position: relative; z-index: 10; display: flex; align-items: center; justify-content: space-between; padding: 15px; transition: 0.3s; }
        body.light-mode .header-v2 { background-color: #291834; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
        .header-title, .hamburger-btn, .lang-btn { color: #ffffff !important; text-shadow: 0 2px 4px rgba(0,0,0,0.5) !important; }
        .hamburger-btn { font-size: 24px; cursor: pointer; }

        .page-content { width: 90%; max-width: 600px; margin: 0 auto 20px; padding: 25px 20px; background: var(--glass-bg); backdrop-filter: blur(12px); border-radius: 20px; text-align: center; box-shadow: 0 15px 35px rgba(0,0,0,0.3); border: 1px solid var(--glass-border); position: relative; z-index: 1; transition: 0.3s; }
        
        /* 🗺️ LE PLAN EN CSS (Ultra-propre) */
        .map-container {
            display: grid;
            grid-template-columns: 1fr 1.5fr 1fr;
            gap: 10px;
            background: var(--bg-body);
            padding: 15px;
            border-radius: 15px;
            border: 2px solid var(--border-line);
            margin-bottom: 25px;
        }
        
        .map-col { display: flex; flex-direction: column; gap: 10px; }
        .map-col-center { display: flex; flex-direction: column; justify-content: space-between; }
        
        .map-box {
            background: var(--card-bg);
            border: 1px solid var(--glass-border);
            border-radius: 8px;
            padding: 10px 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            font-size: 11px;
            font-weight: bold;
            flex: 1;
            color: var(--text-main);
        }
        
        .map-box.stand { border: 2px solid var(--brand, #f8aa37); color: var(--brand, #f8aa37); }
        .map-box.scene { background: rgba(248, 170, 55, 0.15); border: 2px dashed var(--brand, #f8aa37); height: 80px; flex: none; font-size: 14px; }
        .map-box.accueil { background: #4CAF50; color: white; border: none; height: 50px; flex: none; font-size: 14px; }

        /* Chaises de la scène */
        .seats-container { display: grid; grid-template-columns: repeat(5, 1fr); gap: 5px; padding: 10px; opacity: 0.5; }
        .seat { background: var(--text-main); height: 12px; border-radius: 3px; }

        /* Légende */
        .legend-box { background: var(--card-bg); border: 1px solid var(--glass-border); border-radius: 15px; padding: 15px; text-align: left; font-size: 13px; }
        .legend-item { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .legend-color { width: 15px; height: 15px; border-radius: 3px; }

        /* MENU DEROUlant */
        .side-menu, .lang-menu { background: var(--menu-bg) !important; border: 1px solid var(--border-line) !important; box-shadow: -5px 0 15px rgba(0,0,0,0.5); }
        .side-menu { position: fixed; top: 0; right: -250px; width: 250px; height: 100vh; z-index: 3000; transition: right 0.3s ease; display: flex; flex-direction: column; padding: 20px; }
        .side-menu.open { right: 0; }
        .menu-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 2999; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
        .menu-overlay.open { opacity: 1; pointer-events: auto; }
        
        .close-menu { align-self: flex-end; font-size: 30px; cursor: pointer; color: var(--text-main); margin-bottom: 20px; border: none; background: transparent; }
        .side-menu a, .lang-menu div { text-decoration: none; color: var(--text-main) !important; font-size: 16px; font-weight: 600; padding: 15px 10px; border-bottom: 1px solid var(--border-line); display: flex; align-items: center; gap: 10px; transition: 0.2s; cursor: pointer; }
        .side-menu a:hover, .lang-menu div:hover { background: var(--card-bg); color: var(--brand) !important; }

        #night-btn { position: fixed; bottom: 20px; right: 20px; width: 50px; height: 50px; border-radius: 25px; border: none; background: var(--brand, #f8aa37); color: white; font-size: 24px; cursor: pointer; z-index: 3000; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }

        .fade-in { animation: fadeIn 0.6s ease-out forwards; }
        @keyframes fadeIn { 0% { opacity: 0; transform: translateY(15px); } 100% { opacity: 1; transform: translateY(0); } }

        body { top: 0 !important; }
        .skiptranslate { display: none !important; }
    </style>
</head>
<body>
    <div id="google_translate_element" style="display:none;"></div>
    <script>function googleTranslateElementInit() { new google.translate.TranslateElement({pageLanguage: 'fr', autoDisplay: false}, 'google_translate_element'); }</script>
    <script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <div class="fullscreen-bg"></div>

    <div class="header-v2">
        <div class="lang-dropdown" style="position: relative;">
            <div class="lang-btn" onclick="toggleLang()">🇫🇷</div>
            <div class="lang-menu" id="lang-list" style="display:none; position:absolute; top: 35px; left: 0; border-radius:8px; overflow: hidden; z-index: 5000; width: 90px;">
                <div onclick="changeLang('fr', '🇫🇷')">🇫🇷 FR</div>
                <div onclick="changeLang('en', '🇬🇧')">🇬🇧 EN</div>
                <div onclick="changeLang('es', '🇪🇸')">🇪🇸 ES</div>
                <div onclick="changeLang('de', '🇩🇪')">🇩🇪 DE</div>
                <div onclick="changeLang('it', '🇮🇹')">🇮🇹 IT</div>
                <div onclick="changeLang('nl', '🇳🇱')">🇳🇱 NL</div>
                <div onclick="changeLang('zh-CN', '🇨🇳')">🇨🇳 CN</div>
                <div onclick="changeLang('ja', '🇯🇵')">🇯🇵 JA</div>
            </div>
        </div>
        <div class="header-title"><span class="notranslate">Gaming Zone</span><br><span style="font-size: 14px;">24h du Mans</span></div>
        <div class="hamburger-btn" onclick="toggleMenu()">☰</div>
    </div>

    <div class="menu-overlay" id="menu-overlay" onclick="toggleMenu()"></div>
    <div class="side-menu" id="side-menu">
        <button class="close-menu" onclick="toggleMenu()">×</button>
        <a href="index.html">🏠 Accueil</a>
        <a href="defis.html">🎮 Défis</a>
        <a href="plan.html" style="color: var(--brand) !important;">🗺️ Plan de la zone</a>
        <a href="affluence.html">📊 Affluence en direct</a>
        <a href="contact.html">✉️ Contact</a>
        <a href="reglement.html">📜 Règles</a>
        <div style="margin-top: auto; margin-bottom: 20px;">
            <a href="index.html?admin=open" style="border-top: 1px solid var(--border-line); border-bottom: none; font-size: 14px; margin-top: 20px;">🔒 Espace Staff</a>
        </div>
    </div>

    <div class="page-content fade-in">
        <h2 style="margin-bottom: 20px;">Plan interactif</h2>
        
        <div class="map-container">
            <div class="map-col">
                <div class="map-box stand">Mario Party</div>
                <div class="map-box stand">Switch Sports</div>
                <div class="map-box stand">Mario Kart</div>
            </div>
            
            <div class="map-col-center">
                <div class="map-box scene">SCÈNE</div>
                <div class="seats-container">
                    <div class="seat"></div><div class="seat"></div><div class="seat"></div><div class="seat"></div><div class="seat"></div>
                    <div class="seat"></div><div class="seat"></div><div class="seat"></div><div class="seat"></div><div class="seat"></div>
                    <div class="seat"></div><div class="seat"></div><div class="seat"></div><div class="seat"></div><div class="seat"></div>
                    <div class="seat"></div><div class="seat"></div><div class="seat"></div><div class="seat"></div><div class="seat"></div>
                </div>
                <div class="map-box accueil">ACCUEIL</div>
            </div>
            
            <div class="map-col">
                <div class="map-box stand">Just Dance</div>
                <div class="map-box stand">Fall Guys</div>
                <div class="map-box stand">Trackmania</div>
                <div class="map-box stand">Tekken 8</div>
            </div>
        </div>

        <div class="legend-box">
            <h3 style="margin-top: 0; font-size: 16px; margin-bottom: 15px; border-bottom: 1px solid var(--border-line); padding-bottom: 10px;">🕒 Horaires : 10h00 - 21h00</h3>
            
            <div class="legend-item">
                <div class="legend-color" style="border: 2px solid var(--brand, #f8aa37);"></div>
                <span>Stands d'animations (Jeux)</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: #4CAF50;"></div>
                <span>Point de validation & Récupération des cadeaux</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: rgba(248, 170, 55, 0.15); border: 2px dashed var(--brand, #f8aa37);"></div>
                <span>Scène principale & Sièges</span>
            </div>
        </div>

    </div>

    <button id="night-btn" onclick="toggleTheme()">☀️</button>

    <script src="script.js?v=52"></script>
    <script>
        function toggleMenu() { document.getElementById('side-menu').classList.toggle('open'); document.getElementById('menu-overlay').classList.toggle('open'); }
    </script>
</body>
</html>
